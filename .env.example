# =============================================================================
# Forex Predictor API - Environment Configuration Template
# =============================================================================
# Copy this file to '.env' and fill in the values before running the app.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Application Settings ---
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=replace-with-a-strong-random-secret

# --- API Settings ---
API_VERSION=v1
API_PREFIX=/api/v1

# --- Data Source ---
DATA_SOURCE_URL=https://api.example.com/forex-data

# --- Model Paths ---
MODEL_PATH=./model/bitcoin_lstm_model.keras
SCALER_PATH=./model/bitcoin_scaler.pkl
